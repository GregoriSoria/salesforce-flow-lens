{
  "name": "salesforce-flow-lens",
  "displayName": "salesforce-flow-lens",
  "description": "A powerful VS Code extension to visually analyze, compare, and edit Salesforce Flows.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "salesforce-flow-lens.openViewer",
        "title": "Open in Flow Lens",
        "icon": "$(git-compare)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "salesforce-flow-lens.openViewer",
          "when": "resourceFilename =~ /\\.flow-meta\\.xml$/",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "salesforce-flow-lens.openViewer",
          "when": "resourceFilename =~ /\\.flow-meta\\.xml$/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.2",
    "reactive-vscode": "1.0.0-beta.2"
  }
}
